import streamlit as st
import librosa
import numpy as np
import google.generativeai as genai

st.title("🎨 EchoCanvas")

# 1. API Key Input
user_key = st.text_input("Paste your Gemini API Key here:", type="password")

uploaded_file = st.file_uploader("Upload a song", type=["mp3", "wav"])

if uploaded_file and user_key:
    try:
        # Configure Gemini
        genai.configure(api_key=user_key)
        model = genai.GenerativeModel('gemini-1.5-flash')
        
        with st.spinner("Analyzing audio..."):
            y, sr = librosa.load(uploaded_file)
            tempo, _ = librosa.beat.beat_track(y=y, sr=sr)
            
            # Create the prompt
            prompt = f"Describe a painting for a song with {tempo} BPM."
            response = model.generate_content(prompt)
            
            st.success("AI Vision Generated!")
            st.write(response.text)
    except Exception as e:
        st.error(f"Something went wrong: {e}")
elif uploaded_file and not user_key:
    st.warning("Please paste your API key to continue!")
